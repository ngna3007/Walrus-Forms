VITE_SUI_NETWORK=testnet
VITE_FULLNODE_URL=https://fullnode.testnet.sui.io:443
VITE_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Set this after publishing contracts:
# cd contracts && sui client publish --gas-budget 200000000 --json
VITE_PACKAGE_ID=0x0

VITE_WAL_COIN_TYPE=0x8270feb7375eee355e64fdb69c50abb6b5f9393a722883c1cf45f8e26048810a::wal::WAL
VITE_SEAL_THRESHOLD=2
VITE_SESSION_KEY_TTL_MIN=10
VITE_WALRUS_DEFAULT_EPOCHS=5
VITE_WALRUS_USE_SDK=false
